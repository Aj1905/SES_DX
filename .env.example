# === データベース ===
# データ保存先SpreadsheetのID（URLの /d/XXXXX/edit の XXXXX 部分）
SPREADSHEET_ID=
# エラー発生時の通知先メールアドレス
MANAGER_ALERT_EMAIL=

# === Gmailラベル ===
# メール処理状態を管理するラベル名
UNPROCESSED_LABEL='未処理'
PROCESSING_LABEL='処理中'
PROCESSED_LABEL='処理済'
ERROR_LABEL='処理失敗'

# === Spreadsheetシート名 ===
# 各データを保存するシート名（setupApp実行時に自動作成される）
RAW_INBOX_SHEET_NAME=raw_inbox
PARSED_ENTITIES_SHEET_NAME=parsed_entities
NORMALIZED_ENTITIES_SHEET_NAME=normalized_entities
MATCHES_SHEET_NAME=matches
PROCESS_LOG_SHEET_NAME=process_log

# === バッチ設定 ===
# 1回のバッチで取得するスレッド数の上限（実際の処理数は5分の時間制限で決まる）
BATCH_SIZE=100
# 何日前までのメールを検索対象にするか
LOOKBACK_DAYS=30
# トリガー実行間隔（Apps Script UIで設定する場合は不要）
POLL_MINUTES=5

# === マッチング設定 ===
# マッチスコアがこの値以上の候補のみをマッチとみなす
MATCH_THRESHOLD=35
# 1つのエンジニア/案件に対して作成する下書きメールの最大数（スコア上位N件）
MAX_DRAFTS_PER_ITEM=5

# === メール下書きテンプレート ===
# 下書き作成時の送信者名
DRAFT_SENDER_NAME='SES Matching Bot'
# エンジニア宛メールの件名・本文テンプレート（未設定時はConfig.gsのデフォルト値を使用）
ENGINEER_DRAFT_SUBJECT_TEMPLATE=
ENGINEER_DRAFT_BODY_TEMPLATE=
# 案件元宛メールの件名・本文テンプレート（未設定時はConfig.gsのデフォルト値を使用）
PROJECT_DRAFT_SUBJECT_TEMPLATE=
PROJECT_DRAFT_BODY_TEMPLATE=

# === 抽出パイプライン ===
# メール本文からデータを抽出する方式の実行順（regex: 正規表現, ai: AI補完）
EXTRACTOR_PIPELINE='regex,ai'

# === AI API設定 ===
# AI_PROVIDER: 'gemini' または 'openai_compatible'
#
# Gemini の場合（https://aistudio.google.com/apikey でキーを発行）
#   AI_PROVIDER=gemini
#   AI_API_URL=（不要、コード内でモデル名から自動構築）
#   AI_MODEL=gemini-2.0-flash
#
# OpenAI互換の場合（https://platform.openai.com/api-keys でキーを発行）
#   AI_PROVIDER=openai_compatible
#   AI_API_URL=https://api.openai.com/v1/chat/completions
#   AI_MODEL=gpt-4o-mini
AI_PROVIDER=gemini
AI_API_URL=
AI_API_KEY=
AI_MODEL=gemini-2.0-flash
